# Model files (too large for git)
models/

# Runtime data (generated by containers, not versioned)
data/
# Exception: pre-bundled ComfyUI workflows are git-tracked config, not runtime data
!data/comfyui_workflows/
!data/comfyui_workflows/*.json
!data/comfyui_workflows/*.png
!data/comfyui_workflows/*.jpg
!data/comfyui_extra_model_paths.yaml

# Python cache
__pycache__/
*.pyc

# Environment variables (contains secrets — never commit)
.env

# Claude Code workspace
.claude/

# OS
.DS_Store
Thumbs.db
