# Model files (too large for git)
models/
# Exception: router app models directory (Python code, not weights)
!services/router/app/models/

# Runtime data (generated by containers, not versioned)
# Ignore all data/ subdirectories EXCEPT explicitly whitelisted paths below.
data/comfyui_workdir/
data/comfyui_input/
data/comfyui_output/
data/xinference_models/
data/chrome-profile/
data/cookies/
data/router_db/
data/router_redis/
data/rag_chroma/

# Whitelisted: pre-bundled ComfyUI config (workflows, model paths) — git-tracked
# data/comfyui_workflows/   ← tracked (all *.json, *.png, *.jpg, *.mp4)
# data/comfyui_extra_model_paths.yaml  ← tracked

# Python cache
__pycache__/
*.pyc

# Environment variables (contains secrets — never commit)
.env

# Claude Code workspace
.claude/

# OS
.DS_Store
Thumbs.db
